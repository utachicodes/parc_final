# ── Synchronisation ───────────────────────────────────────────────────────────
# Set to "sync" to start the bridge (simulation → real arm).
# Leave empty to run simulation and controller independently.
COMPOSE_PROFILES=

# ── Real arm ──────────────────────────────────────────────────────────────────
# Serial port the SO-101 is connected to
SERIAL_PORT=/dev/ttyACM0

# ── MuJoCo assets ─────────────────────────────────────────────────────────────
# Directory that contains so_101.xml (mounted read-only into the sim container)
SO101_DIR=/home/parc/Desktop/InverseKinematics/so101-inverse-kinematics-main/so101

# ── Bridge tuning ─────────────────────────────────────────────────────────────
# Max joint commands per second sent to the real arm
RATE_HZ=20

# ── Exposed ports (change if conflicts) ───────────────────────────────────────
CONTROLLER_PORT=5000
HTTP_PORT=38000
WS_PORT=38001
